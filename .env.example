# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LAYOUT_MODEL=gpt-4.1
OPENAI_ORDER_MODEL=gpt-4.1-mini
FINE_TUNED_LAYOUT_MODEL=

# Local LoRA training for Method 3
LORA_BASE_MODEL=Qwen/Qwen3-4B-Instruct-2507
LORA_OUTPUT_DIR=outputs/lora/method3
LORA_TRAIN_PATH=outputs/fine_tuning/method3_train.jsonl
LORA_VALIDATION_PATH=outputs/fine_tuning/method3_validation.jsonl
LORA_MAX_LENGTH=2048
LORA_EPOCHS=3
LORA_BATCH_SIZE=1
LORA_GRADIENT_ACCUMULATION_STEPS=8
LORA_RANK=16
LORA_ALPHA=32
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj
LORA_LOAD_IN_4BIT=false
LORA_FAIL_ON_TRUNCATION=true

# Google Gemini
GOOGLE_API_KEY=
GEMINI_LAYOUT_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_LAYOUT_MODEL=claude-sonnet-4-5
CLAUDE_FAST_MODEL=claude-haiku-4-5

# Experiment defaults
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=local
DEFAULT_LAYOUT_MODEL=gpt-4.1
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EXPERIMENT_RUN_ID=latest
EXPERIMENT_OUTPUT_ROOT=outputs/experiments
EXPERIMENT_LLM_PROVIDERS=openai,gemini,claude
FORMS_PATH=data/processed/sample_forms.jsonl
ORDER_CONSTRAINTS_PATH=data/processed/order_constraints.jsonl

# Graph method
GRAPH_SIMILARITY_THRESHOLD=0.25
GRAPH_COMMUNITY_ALGORITHM=leiden
GRAPH_RANDOM_SEED=42

# Output / logging
LOG_LEVEL=INFO
SAVE_RAW_LLM_RESPONSES=true
TRACK_TOKEN_USAGE=true

# Method runners
INCLUDE_LLM_SINGLE=false
INCLUDE_LLM_MULTI_AGENT=false
INCLUDE_FINE_TUNED_MODEL=false
INCLUDE_HYBRID=false
INCLUDE_LOCAL_LORA=false

# Silver reference layout construction for Method 3 fine-tuning
SILVER_LAYOUT_INPUT=data/splits/train.jsonl
SILVER_LAYOUT_OUTPUT=outputs/fine_tuning/silver_train_forms.jsonl
SILVER_LAYOUT_AUDIT_OUTPUT=outputs/fine_tuning/silver_train_audit.jsonl
SILVER_LAYOUT_SUMMARY_DIR=outputs/fine_tuning/silver_summary
SILVER_LAYOUT_PROVIDERS=openai,claude,gemini
SILVER_OPENAI_MODEL=gpt-5.4-mini
SILVER_CLAUDE_MODEL=claude-sonnet-4-20250514
SILVER_GEMINI_MODEL=gemini-2.5-flash-lite
SILVER_LAYOUT_START=0
SILVER_LAYOUT_LIMIT=
SILVER_PROVIDER_WORKERS=
SILVER_FORM_WORKERS=1
SILVER_PROVIDER_RETRIES=2
SILVER_RETRY_DELAY_SECONDS=2.0
FINE_TUNING_FORMS_PATH=outputs/fine_tuning/silver_train_forms.jsonl
FINE_TUNING_OUTPUT_PATH=outputs/fine_tuning/method3_train.jsonl
FINE_TUNING_AUGMENT=true
