# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LAYOUT_MODEL=gpt-4.1
OPENAI_ORDER_MODEL=gpt-4.1-mini
FINE_TUNED_LAYOUT_MODEL=

# Local LoRA training for Method 3
LORA_BASE_MODEL=Qwen/Qwen3-4B-Instruct-2507
LORA_OUTPUT_DIR=outputs/lora/method3
LORA_MAX_LENGTH=2048
LORA_EPOCHS=3
LORA_BATCH_SIZE=1
LORA_GRADIENT_ACCUMULATION_STEPS=8
LORA_RANK=16
LORA_ALPHA=32
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj
LORA_LOAD_IN_4BIT=false

# Google Gemini
GOOGLE_API_KEY=
GEMINI_LAYOUT_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_LAYOUT_MODEL=claude-sonnet-4-5
CLAUDE_FAST_MODEL=claude-haiku-4-5

# Experiment defaults
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=local
DEFAULT_LAYOUT_MODEL=gpt-4.1
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Graph method
GRAPH_SIMILARITY_THRESHOLD=0.25
GRAPH_COMMUNITY_ALGORITHM=leiden
GRAPH_RANDOM_SEED=42

# Output / logging
LOG_LEVEL=INFO
SAVE_RAW_LLM_RESPONSES=true
TRACK_TOKEN_USAGE=true

# Method runners
INCLUDE_LLM_SINGLE=false
INCLUDE_LLM_MULTI_AGENT=false
INCLUDE_FINE_TUNED_MODEL=false
INCLUDE_HYBRID=false
