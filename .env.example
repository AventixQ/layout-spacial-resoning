# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LAYOUT_MODEL=gpt-4.1
OPENAI_ORDER_MODEL=gpt-4.1-mini

# Google Gemini
GOOGLE_API_KEY=
GEMINI_LAYOUT_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_LAYOUT_MODEL=claude-sonnet-4-5
CLAUDE_FAST_MODEL=claude-haiku-4-5

# Experiment defaults
DEFAULT_LLM_PROVIDER=openai
DEFAULT_EMBEDDING_PROVIDER=local
DEFAULT_LAYOUT_MODEL=gpt-4.1
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# Graph method
GRAPH_SIMILARITY_THRESHOLD=0.25
GRAPH_COMMUNITY_ALGORITHM=leiden
GRAPH_RANDOM_SEED=42

# Output / logging
LOG_LEVEL=INFO
SAVE_RAW_LLM_RESPONSES=true
TRACK_TOKEN_USAGE=true
